<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta name=”renderer” content=”webkit|ie-comp|ie-stand” />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="content-type" content="text/html; charset=UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <link rel="icon" href="~/favicon.ico">

    <title>@ViewBag.Title</title>
    <link href="~/lib/pace/pace-theme-minimal.css" rel="stylesheet" />
    <link href="~/font/css/font-awesome.min.css" rel="stylesheet" />
    <link href="~/lib/bootstrap/bootstrap.min.css" rel="stylesheet" />

    <script src="~/lib/pace/pace.min.js"></script>
    <script src="~/js/jquery-1.10.2.min.js"></script>
    <script src="~/lib/bootstrap/bootstrap.min.js"></script>
    <script src="~/lib/jqprint/jquery.jqprint-0.3.js"></script>
    <script src="~/lib/laydate/laydate.js"></script>

    @Html.AppendCssFile(
                            "/lib/aycsoft/style/lr-common.css",
                            "/lib/aycsoft/plugin/scroll/scroll.css",
                            "/lib/aycsoft/style/lr-iframe-index.css",

                            "/lib/aycsoft/plugin/layout/lr-layout.css",
                            "/lib/aycsoft/plugin/tree/lr-tree.css",
                            "/lib/aycsoft/plugin/select/lr-select.css",
                            "/lib/aycsoft/plugin/timeline/lr-timeline.css",
                            "/lib/aycsoft/plugin/formselect/lr-formselect.css",
                            "/lib/aycsoft/plugin/layerselect/lr-layerselect.css",
                            "/lib/aycsoft/plugin/date/lr-datepicker.css",
                            "/lib/aycsoft/plugin/uploader/lr-uploader.css",
                            "/lib/aycsoft/plugin/grid/jfgrid.css",
                            "/lib/aycsoft/plugin/gantt/lrGantt.css"

                            )

    <!--[if lt IE 9]>
      <script src="~/lib/bootstrap/html5shiv.min.js"></script>
      <script src="~/lib/bootstrap/respond.min.js"></script>
    <![endif]-->
    <script>function request(d) { for (var c = location.search.slice(1).split("&"), a = 0; a < c.length; a++) { var b = c[a].split("="); if (b[0] == d) if ("undefined" == unescape(b[1])) break; else return decodeURI(unescape(b[1])) } return "" };</script>
    @Html.SetCurrentUrl()
</head>
<body>
    @RenderBody()

    @Html.AppendJsFile(
                            "/lib/aycsoft/plugin/resize/resize.js",
                            "/lib/aycsoft/plugin/mousewheel/mousewheel.js",
                            "/lib/aycsoft/plugin/scroll/scroll.js",

                            "/lib/aycsoft/plugin/layout/lr-layout.js",
                            "/lib/aycsoft/plugin/tree/lr-tree.js",
                            "/lib/aycsoft/plugin/select/lr-select.js",
                            "/lib/aycsoft/plugin/timeline/lr-timeline.js",
                            "/lib/aycsoft/plugin/formselect/lr-formselect.js",
                            "/lib/aycsoft/plugin/layerselect/lr-layerselect.js",
                            "/lib/aycsoft/plugin/date/lr-datepicker.js",
                            "/lib/aycsoft/script/lr-validator.js",
                            "/lib/aycsoft/script/lr-authorize.js",
                            "/lib/aycsoft/script/lr-excel.js",
                            "/lib/aycsoft/script/lr-form.js",
                            "/lib/aycsoft/plugin/uploader/lr-uploader.js",
                            "/lib/aycsoft/plugin/grid/jfgrid.js",
                            "/lib/aycsoft/plugin/gantt/lrGantt.js"
                            )
    <script>$(function () {
            var uitheme = top.$.cookie('lr_adms_core_ui') || '1';
            var uiclass = '';
            switch (uitheme) {
                case "1":
                    uiclass = "lr-uitheme-default";     // 经典版本
                    break;
                case "2":
                    uiclass = "lr-uitheme-accordion";   // 手风琴版本
                    break;
                case "3":
                    uiclass = "lr-uitheme-windos";      // Windos版本
                    break;
                case "4":
                    uiclass = "lr-uitheme-top";        // 顶部菜单版本
                    break;
                default:
                    uiclass = "lr-uitheme-default";     // 经典版本
                    break;
            }
            $('body').addClass(uiclass);

            $('#lr_layout').lrLayout();

            // 翻译指定标签
            $('.lrlg').each(function () {
                var $this = $(this);
                top.aycsoft.language.get($this.text(), function (text) {
                    $this.text(text);
                });
            });
            // 翻译表单标题
            $('.lr-form-item-title').each(function () {
                var $this = $(this);
                var $font = $this.find('font');
                $font.remove();
                top.aycsoft.language.get($this.text(), function (text) {
                    if ($font.length > 0) {
                        $this.html(text + '<font face="宋体">*</font>');
                    }
                    else {
                        $this.text(text);
                    }

                });
            });
            // input placeholder 翻译
            $('input[placeholder]').each(function () {
                var $this = $(this);
                var _text = $this.attr('placeholder');
                top.aycsoft.language.get(_text, function (text) {
                    $this.attr('placeholder', text);
                });
            });
            if (lrCurrentMouldeCode) {
                top.aycsoft.httpAsync('GET', top.$.rootUrl + '/LR_SystemModule/Module/GetAuthorizeButtonColumnList', { code: lrCurrentMouldeCode }, function (data) {
                    lrModuleButtonList = data.btns;
                    lrModuleColumnList = data.cols;
                    lrModuleForms = data.forms;
                    lrModule = data.module;
                    window.bootstrap && window.bootstrap(jQuery, top.aycsoft);
                });
            }
            else {
                lrModuleButtonList = [];
                lrModuleColumnList = [];
                lrModuleForms = null;
                lrModule = {};

                window.bootstrap && window.bootstrap(jQuery, top.aycsoft);
            }
        });</script>
</body>

</html>
