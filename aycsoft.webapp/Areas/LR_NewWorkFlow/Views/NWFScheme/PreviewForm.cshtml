
@{
    ViewData["Title"] = "流程模板预览";
    Layout = "~/Views/Shared/_Index.cshtml";
}
<link href="~/lib/aycsoft/plugin/workflownew/lr-workflow-ui.css" rel="stylesheet" />
<script src="~/lib/aycsoft/plugin/workflownew/lr-workflow-ui.js"></script>
<div style="position:relative;width:100%;height:100%;">
    <div style="position:relative;width:100%;height:100%;" id="flow">

    </div>
</div>
<script>
    var schemeId = request('schemeId');
    var currentNode;
    var currentLine;
    var bootstrap = function ($, aycsoft) {
        "use strict";

        var page = {
            init: function () {
                // 设计页面初始化
                $('#flow').lrworkflow({
                    isPreview: true,
                    openNode: function (node) {
                        currentNode = node;
                        if (node.type != 'endround') {
                            aycsoft.layerForm({
                                id: 'NodeForm',
                                title: '节点信息设置【' + node.name + '】',
                                url: top.$.rootUrl + '/LR_NewWorkFlow/NWFScheme/NodeForm?layerId=layer_PreviewForm&isPreview=1',
                                width: 700,
                                height: 500,
                                btn: null
                            });
                        }
                    }
                });

                if (!!schemeId) {
                    $.lrSetForm(top.$.rootUrl + '/LR_NewWorkFlow/NWFScheme/GetScheme?schemeId=' + schemeId, function (res) {
                        var shceme = JSON.parse(res.F_Content);
                        $('#flow').lrworkflowSet('set', { data: shceme });
                    });
                }
            }
        };

        page.init();
    }
</script>
