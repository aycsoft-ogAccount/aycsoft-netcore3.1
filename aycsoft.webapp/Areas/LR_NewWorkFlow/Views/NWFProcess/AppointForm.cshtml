@{
    ViewBag.Title = "指定审核人";
    Layout = "~/Views/Shared/_Form.cshtml";
}
<style>

    .lr-form-item {
        padding: 5px 0 5px 200px;
    }

    .lr-form-item-title {
        width: 200px;
    }
    .divtext {
        position: relative;
        width: 100%;
        height: 28px;
        line-height: 26px;
        border: 1px solid #ccc;
        padding-left: 4px;
        cursor: pointer;
        color: #333;
    }
</style>
<div class="lr-form-wrap" id="form">
</div>
<script>
    var processId = request('processId');
var acceptClick;

var bootstrap = function ($, aycsoft) {
    "use strict";

    var taskMap = {};
    var userMap = {};
    var page = {
        init: function () {
            var userList = [];
            // 获取当前任务的审核人
            aycsoft.httpAsync('GET', top.$.rootUrl + '/LR_NewWorkFlow/NWFProcess/GetTaskUserList', { processId: processId }, function (data) {
                if (data) {
                    var $form = $('#form');
                    $.each(data, function (_index, _item) {
                        taskMap[_item.F_Id] = _item;
                        var nameList = [];
                        $.each(_item.nWFUserInfoList, function (_jindex,_jitem) {
                            nameList.push(_jitem.Id);
                        });

                        var _html = '<div class="col-xs-12 lr-form-item">\
                                        <div class="lr-form-item-title">' + _item.F_NodeName + '【当前】</div>\
                                        <div id="' + _item.F_Id + '_i" class="divtext" ></div>\
                                    </div>\
                                    <div class="col-xs-12 lr-form-item">\
                                        <div class="lr-form-item-title">' + _item.F_NodeName + '【设置】</div>\
                                        <div id="' + _item.F_Id + '" ></div>\
                                    </div>';

                        $form.append(_html);

                        $('#' + _item.F_Id).lrUserSelect(1);
                        loadUserInfo(_item.F_Id + '_i',nameList);
                        
                    });
                }
            });
        }
    };
    function loadUserInfo(id,nameList) {
        aycsoft.httpAsync('GET', top.$.rootUrl + '/LR_OrganizationModule/User/GetEntityListByUserIds', { userIds: String(nameList) }, function (data) {
            if (data) {
                var $item = $('#' + id);
                $.each(data, function (_index, _user) {
                    var _html = '';
                    if (_index > 0) {
                        _html += ',';
                    }
                    if (_user.F_DepartmentId) {
                        _html += '【<span dpId="' + _user.F_DepartmentId + '" ></span>】';                      
                    }
                    _html += _user.F_RealName;
                    $item.append(_html);
                    if (_user.F_DepartmentId) {
                        aycsoft.clientdata.getAsync('department', {
                                key: _user.F_DepartmentId,
                                callback: function (department) {
                                    $('[dpId="' + _user.F_DepartmentId + '"]').text(department.F_FullName);
                                }
                        });
                    }
                })
            }
            console.log(data,'123');
        });
    }


    // 保存数据
    acceptClick = function (callBack) {
        var formData = $('#form').lrGetFormData();
        var postData = [];
        $.each(formData || {}, function (_id, _item) {
            if (_item) {
                var point = taskMap[_id];
                if (point) {
                    var userList = _item.split(',');
                    var userNameList = $('#' + _id + ' span').text().split(',');
                    point.nWFUserInfoList = [];
                    $.each(userList, function (_i, _u) {
                        point.nWFUserInfoList.push({ Id: _u, Name: userNameList[_i] });
                    });

                    postData.push(point);
                }
            }
        });
        if (postData.length > 0) {
            $.lrSaveForm(top.$.rootUrl + '/LR_NewWorkFlow/NWFProcess/AppointUser', { strList: JSON.stringify(postData) }, function (res) {
                // 保存成功后才回调
                callBack && callBack();
            });
        }
        else {
            return true;
        }
    };
    page.init();
}
</script>

