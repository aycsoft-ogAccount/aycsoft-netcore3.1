
@{
    ViewData["Title"] = "选择发起流程模板";
    Layout = "~/Views/Shared/_Form.cshtml";
}
<style>
.form-warp {
    position: relative;
    width: 100%;
    height: 100%;
    padding-top: 40px;
}
.top {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 40px;
    border-bottom:1px solid #ccc;
    padding-right:10px;
}


.form-warp-left {
    position: absolute;
    left: 0;
    top: 0;
    width: 200px;
    height: 100%;
}


.lr-left-tree {
    position: relative;
    height: 100%;
    width: 100%;
    border-right: 1px solid #ddd;
    padding-top: 5px;
}



.form-warp-main {
    position: relative;
    height: 100%;
    width: 100%;
    padding-top: 28px;
}

.input-search {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 28px;
    border-bottom: 1px solid #ddd;
}

.form-control {
    border: 0px;
    height: 100%;
}

.input-query {
    position: absolute;
    right: 8px;
    top: 2px;
    color: #ccc;
    font-size: 16px;
    cursor: pointer;
}






.main-list {
    position: relative;
    height: 100%;
    width: 100%;
    overflow-y:auto;
}

.card-box {
    position: relative;
    float: left;
    width: 190px;
    height: 60px;
    border: 1px solid #ccc;
    background-color: #fff;
    border-radius: 3px;
    margin: 10px 0 0 10px;
    padding-left: 65px;
    padding-top: 4px;
    overflow: hidden;
    -moz-user-select: none;
    -webkit-user-select: none;
    -ms-user-select: none;
    -khtml-user-select: none;
    user-select: none;
    cursor: pointer;
}

    .card-box.active {
        border: 1px solid #ff5d5b;
        background: url(/img/selected_red.png) right top no-repeat;
    }

.card-box-img {
    position: absolute;
    left: 0;
    top: 0;
    width: 60px;
    height: 58px;
    border-right: 1px solid #ccc;
}

    .card-box-img img {
        width: 59px;
        height: 58px;
    }

.card-box-content p {
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    margin: 0;
}

</style>
<div class="form-warp">
    <div class="top">
        <div class="col-xs-12 lr-form-item">
            <div class="lr-form-item-title">流程发起人</div>
            <div id="createUser"></div>
        </div>
    </div>
    <div class="lr-rblock" style="padding-left:200px;">
        <div class="form-warp-left">
            <div id="lr_left_tree" class="lr-left-tree"></div>
        </div>
        <div class="form-warp-main">
            <div class="input-search">
                <input id="txt_keyword" type="text" class="form-control" placeholder="请输入要查询关键字">
                <span class="input-query" title="Search"><i class="fa fa-search"></i></span>
            </div>
            <div class="main-list" id="main_list"></div>
        </div>
    </div>
</div>
<script>
var acceptClick;
var bootstrap = function ($, aycsoft) {
    "use strict";
    var categoryId = '';
    var keyword = '';
    var schemeList = [];


    var render = function () {
        var $warp = $('<div></div>');
        var ponit;
        for (var i = 0, l = schemeList.length; i < l; i++) {
            ponit = null;
            var item = schemeList[i];
            if (categoryId != '') {
                if (item.F_Category == categoryId) {
                    ponit = item;
                }
            }
            else {
                ponit = item;
            }

            if (!!ponit) {
                if (keyword != '') {
                    if (ponit.F_Name.indexOf(keyword) == -1 && ponit.F_Code.indexOf(keyword) == -1) {
                        ponit = null;
                    }
                }
            }
            if (!!ponit) {// 刷新流程模板数据
                var _cardbox = "";
                _cardbox += '<div class="card-box" data-value="' + item.F_Code + '" >';
                _cardbox += '    <div class="card-box-img">';
                _cardbox += '        <img src="' + top.$.rootUrl + '/img/filetype/Scheme.png" />';
                _cardbox += '    </div>';
                _cardbox += '    <div class="card-box-content">';
                _cardbox += '        <p>名称：' + item.F_Name + '</p>';
                _cardbox += '        <p>编号：' + item.F_Code + '</p>';
                _cardbox += '    </div>';
                _cardbox += '</div>';
                var $cardbox = $(_cardbox);
                $cardbox[0].shceme = item;
                $warp.append($cardbox);
            }
        }
        $warp.find('.card-box').on('click', function () {
            var $this = $(this);

            if ($this.hasClass('active')) {
                $this.removeClass('active');
            }
            else {
                $warp.find('.card-box.active').removeClass('active');
                $this.addClass('active');
            }
        });

        $('#main_list').html($warp);
    }

    var page = {
        init: function () {
            page.bind();
        },
        bind: function () {
            //// 加载自定义流程列表
            aycsoft.httpAsync('GET', top.$.rootUrl + '/LR_NewWorkFlow/NWFScheme/GetInfoList', {}, function (data) {
                schemeList = data;
                render();
            });

            // 左侧数据加载
            $('#lr_left_tree').lrtree({
                url: top.$.rootUrl + '/LR_SystemModule/DataItem/GetDetailTree',
                param: { itemCode: 'FlowSort' },
                nodeClick: function (item) {
                    categoryId = item.value;
                    render();
                }
            });

            $("#txt_keyword").keydown(function (event) {
                if (event.keyCode == 13) {
                    keyword = $(this).val();
                    render();
                }
            });
            

            $('#createUser').lrUserSelect(0, function (item) {
                console.log(item);
                aycsoft.httpAsync('GET', top.$.rootUrl + '/LR_NewWorkFlow/NWFScheme/GetInfoList', {userId:item.value}, function (data) {
                    schemeList = data;
                    render();
                });
            });
            var loginInfo = aycsoft.clientdata.get(['userinfo']);
            $('#createUser').lrformselectSet(loginInfo.F_UserId);
        }
    };
    // 保存数据
    acceptClick = function () {
        var $selected = $('#main_list').find('.card-box.active');
        var shcemeCode = $selected.attr('data-value');
        if (!!shcemeCode) {
            var id = $selected[0].shceme.F_Id;
            // 发起流程
            var createUser = $('#createUser').lrformselectGet();
            aycsoft.frameTab.open({ F_ModuleId: id, F_Icon: 'fa magic', F_FullName: '发起流程【' + $selected[0].shceme.F_Name + '】', F_UrlAddress: '/LR_NewWorkFlow/NWFProcess/NWFContainerForm?shcemeCode=' + shcemeCode + '&tabIframeId=' + id + '&type=create' + "&createUserId=" + createUser });
            return true;
        }
        else {
            aycsoft.alert.error('请选择流程模板');
            return false;
        }
    };
    page.init();
}
</script>
