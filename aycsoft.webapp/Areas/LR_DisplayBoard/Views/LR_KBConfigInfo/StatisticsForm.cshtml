@{
    ViewBag.Title = "StatisticsForm";
    Layout = "~/Views/Shared/_Form.cshtml";
}
<style>

    .lr-form-item-text {
        position: absolute;
        top: 7px;
        right: 0;
        padding: 4px 8px;
        color: #000;
    }
</style>
<div class="lr-form-wrap" id="form">
    <div class="col-xs-12 lr-form-item ">
        <div class="lr-form-item-title">模块名称<font face="宋体">*</font></div>
        <input id="F_ModeName" type="text" class="form-control" isvalid="yes" checkexpession="NotNull" />
    </div>
    <div class="col-xs-12 lr-form-item">
        <div class="lr-form-item-title">模块上边距<font face="宋体">*</font></div>
        <input id="F_TopValue" type="text" class="form-control" isvalid="yes" checkexpession="Num" />
    </div>
    <div class="col-xs-12 lr-form-item">
        <div class="lr-form-item-title">模块左边距<font face="宋体">*</font></div>
        <div id="F_LeftValue" isvalid="yes" checkexpession="NotNull">
            <ul>
                <li data-value="0">0</li>
                <li data-value="1/4">25%</li>
                <li data-value="1/3">33%</li>
                <li data-value="1/2">50%</li>
                <li data-value="2/3">66%</li>
                <li data-value="3/4">75%</li>
            </ul>
        </div>
    </div>
    <div class="col-xs-12 lr-form-item">
        <div class="lr-form-item-title">模块宽度<font face="宋体">*</font></div>
        <div id="F_WidthValue" isvalid="yes" checkexpession="NotNull">
            <ul>
                <li data-value="1">100%</li>
                <li data-value="3/4">75%</li>
                <li data-value="2/3">66%</li>
                <li data-value="1/2">50%</li>
                <li data-value="1/3">33%</li>
                <li data-value="1/4">25%</li>
            </ul>
        </div>
    </div>
    <div class="col-xs-12 lr-form-item">
        <div class="lr-form-item-title">刷新时间</div>
        <input id="F_RefreshTime" type="text" class="form-control" isvalid="yes" checkexpession="NumOrNull" />
        <span class="lr-form-item-text">分钟</span>
    </div>
</div>
<script>
    var acceptClick;
var bootstrap = function ($, aycsoft) {
    "use strict";
    var selectedModel = top.layer_form.selectedModel;

    var page = {
        init: function () {
            page.bind();
            page.initData();
        },
        bind: function () {
            ///显示比例
            $('#F_WidthValue').lrselect();
            $('#F_LeftValue').lrselect();
        },
        initData: function () {
            if (selectedModel) {
                $('#form').lrSetFormData(selectedModel);
            }
        }
    };
    // 保存数据
    acceptClick = function (callBack) {
        if (!$('#form').lrValidform()) {
            return false;
        }
        var formData = $('#form').lrGetFormData();
        formData.F_Configuration = '';
        formData.F_Type = 'statistics';
        formData.F_HightValue = '257';
        if (selectedModel) {
            selectedModel.F_ModeName = formData.F_ModeName;
            selectedModel.F_TopValue = formData.F_TopValue;
            selectedModel.F_LeftValue = formData.F_LeftValue;
            selectedModel.F_HightValue = formData.F_HightValue;
            selectedModel.F_WidthValue = formData.F_WidthValue;
            selectedModel.F_RefreshTime = formData.F_RefreshTime;
        }
        
        callBack(formData);
        return true;
    };
    page.init();
}
</script>


