@{
    ViewBag.Title = "数据库管理";
    Layout = "~/Views/Shared/_Form.cshtml";
}
<div class="lr-form-wrap" id="form">
    <div class="col-xs-6 lr-form-item">
        <div class="lr-form-item-title">编码<font face="宋体">*</font></div>
        <input id="F_DBName" type="text" class="form-control" placeholder="请输入别名" isvalid="yes" checkexpession="NotNull" />
    </div>
    <div class="col-xs-6 lr-form-item">
        <div class="lr-form-item-title">名称<font face="宋体">*</font></div>
        <input id="F_DBAlias" type="text" class="form-control" placeholder="请输入名称" isvalid="yes" checkexpession="NotNull" />
    </div>
    <div class="col-xs-12 lr-form-item">
        <div class="lr-form-item-title">库类型<font face="宋体">*</font></div>
        <div id="F_DbType" isvalid="yes" checkexpession="NotNull"></div>
    </div>
    <div class="col-xs-12 lr-form-item lr-form-btnitem">
        <div class="lr-form-item-title">连接串</div>
        <input id="F_DbConnection" type="text" class="form-control" isvalid="yes" checkexpession="NotNull" />
        <a id="lr_test" class="btn btn-default lr-form-item-btn">测试连接</a>
    </div>
    <div class="col-xs-12 lr-form-item">
        <div class="lr-form-item-title">描述</div>
        <textarea id="F_Description" type="text" class="form-control" style="height:110px;"></textarea>
    </div>
</div>
<script>var keyValue = "";
    var acceptClick;
    var bootstrap = function ($, aycsoft) {
        "use strict";
        var selectedRow = aycsoft.frameTab.currentIframe().selectedRow;
        var page = {
            init: function () {
                page.bind();
                page.initData();
            },
            bind: function () {
                $('#F_DbType').lrDataItemSelect({ code: 'DbVersion' });
                /*检测重复项*/
                $('#F_DBName').on('blur', function () {
                    $.lrExistField(keyValue, 'F_DBName', 'lr_base_databaselink', 'F_DatabaseLinkId');
                });
                $('#lr_test').on('click', function () {
                    var dbType = $('#F_DbType').lrselectGet();
                    if (!dbType) {
                        aycsoft.alert.error('请选择数据库类型');
                        return false;
                    }
                    var connection = $('#F_DbConnection').val();
                    if (!connection) {
                        aycsoft.alert.error('请填写数据库连接串');
                        return false;
                    }
                    $.lrPostForm(top.$.rootUrl + '/LR_SystemModule/DatabaseLink/TestConnection', { connection: connection, dbType: dbType, keyValue: keyValue });
                });
            },
            initData: function () {
                if (!!selectedRow) {
                    keyValue = selectedRow.F_DatabaseLinkId;
                    $('#form').lrSetFormData(selectedRow);
                }
            }
        };
        // 保存数据
        acceptClick = function (callBack) {
            if (!$('#form').lrValidform()) {
                return false;
            }
            var postData = $('#form').lrGetFormData(keyValue);
            $.lrSaveForm(top.$.rootUrl + '/LR_SystemModule/DatabaseLink/SaveForm?keyValue=' + keyValue, postData, function (res) {
                // 保存成功后才回调
                if (!!callBack) {
                    callBack();
                }
            });
        };
        page.init();
    }</script>
