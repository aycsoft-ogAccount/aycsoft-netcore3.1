@{
    ViewBag.Title = "即时通讯用户管理";
    Layout = "~/Views/Shared/_Form.cshtml";
}
<div class="lr-form-wrap" id="form">
    <div class="col-xs-12 lr-form-item">
        <div class="lr-form-item-title">用户名称<font face="宋体">*</font></div>
        <input id="F_Name" type="text" class="form-control" placeholder="请输入名称" isvalid="yes" checkexpession="NotNull" />
    </div>
    <div class="col-xs-12 lr-form-item">
        <div class="lr-form-item-title">用户编码<font face="宋体">*</font></div>
        <input id="F_Code" type="text" class="form-control" placeholder="请输入编码" isvalid="yes" checkexpession="NotNull" />
    </div>
    <div class="col-xs-12 lr-form-item">
        <div class="lr-form-item-title">图标</div>
        <input id="F_Icon" type="text" class="form-control" placeholder="请选择图标" />
        <span id="selectIcon" class="lr-input-button" title="选取图标">...</span>
    </div>
    <div class="col-xs-12 lr-form-item">
        <div class="lr-form-item-title">备注</div>
        <textarea id="F_Description" type="text" class="form-control" style="height:160px;"></textarea>
    </div>
</div>
<script>var keyValue = request('keyValue');

    var acceptClick;
    var bootstrap = function ($, aycsoft) {
        "use strict";

        var page = {
            init: function () {
                // 验证编码是否重复
                $('#F_Code').on('blur', function () {
                    $.lrExistField(keyValue, 'F_Code', 'lr_im_sysuser', 'F_Id');
                });
                // 选择图标
                $('#selectIcon').on('click', function () {
                    aycsoft.layerForm({
                        id: 'iconForm',
                        title: '选择图标',
                        url: top.$.rootUrl + '/Utility/Icon',
                        height: 700,
                        width: 1000,
                        btn: null,
                        maxmin: true,
                        end: function () {
                            if (top._aycsoftSelectIcon != '') {
                                $('#F_Icon').val(top._aycsoftSelectIcon);
                            }
                        }
                    });
                });

                page.initData();
            },
            initData: function () {
                if (!!keyValue) {
                    aycsoft.httpAsync('GET', top.$.rootUrl + '/LR_IM/SysUser/GetFormData', { keyValue: keyValue }, function (data) {
                        $('#form').lrSetFormData(data);
                    });
                }
            }
        };
        // 保存数据
        acceptClick = function (callBack) {
            if (!$('#form').lrValidform()) {
                return false;
            }
            var postData = $('#form').lrGetFormData(keyValue);
            $.lrSaveForm(top.$.rootUrl + '/LR_IM/SysUser/SaveForm?keyValue=' + keyValue, postData, function (res) {
                // 保存成功后才回调
                if (!!callBack) {
                    callBack();
                }
            });
        };
        page.init();
    }</script>
